# ============================================================
# ThriftBazaar Backend — Environment Variable Template
# ============================================================
# Copy this file to a file named exactly:  .env
# (or set the variables in your shell / deployment platform)
# then fill in the values for your environment.
#
# The application.properties file reads every value from these
# environment variables via the ${VAR_NAME} syntax, so NO
# secrets ever need to be written directly into source files.
# ============================================================

# ── Server ──────────────────────────────────────────────────
# Port the embedded Tomcat listens on (default: 8081)
SERVER_PORT=8081

# ── PostgreSQL ───────────────────────────────────────────────
# Full JDBC connection URL
DB_URL=jdbc:postgresql://localhost:5432/thriftbazaar
# Database username
DB_USERNAME=postgres
# Database password  ← REQUIRED, no default
DB_PASSWORD=arnav123

# ── Cloudinary ───────────────────────────────────────────────
# All three values are required — find them in your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=doioxjo6e
CLOUDINARY_API_KEY=849977999455925
CLOUDINARY_API_SECRET=uidV2WE65sLMH9b3F2wJe9X6a_0

# ── JWT ──────────────────────────────────────────────────────
# HMAC-SHA256 signing secret.
# MUST be at least 32 characters (256 bits) of random data.
# Generate with:  openssl rand -hex 32
JWT_SECRET="3409fe6f-0397-4366-992a-d9baf8a49bcf87f3fc08-4427-44b8-a349-7bf98a9c8ef7"
# Token lifetime in milliseconds (default: 3600000 = 1 hour)
JWT_EXPIRATION_MS=3600000

# ── CORS ─────────────────────────────────────────────────────
# The exact origin(s) allowed to make cross-origin requests.
# In production this should be your deployed frontend URL.
CORS_ALLOWED_ORIGIN=http://localhost:5173
